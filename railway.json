{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "sh -c 'cd /app/backend && uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}'",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  },
  "crons": [
    {
      "name": "oura-daily-sync",
      "schedule": "0 6 * * *",
      "command": "cd /app/backend && python -m app.services.oura_service",
      "comment": "COA-26: Pull yesterday Oura readiness, sleep, HRV for all athletes at 6 AM UTC daily"
    }
  ]
}
