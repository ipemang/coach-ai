# Supabase — get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Backend URL (Railway backend service)
BACKEND_URL=https://coach-ai-production-a5aa.up.railway.app

# Coach identity — used for single-coach dashboard
COACH_ID=your-coach-uuid

# Organization ID (used for invite flows)
ORGANIZATION_ID=1
