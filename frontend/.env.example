# Supabase — get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Backend URL (Railway backend service)
BACKEND_URL=https://coach-ai-production-a5aa.up.railway.app
# Public backend URL — used in browser-side fetch calls (onboarding, etc.)
NEXT_PUBLIC_BACKEND_URL=https://coach-ai-production-a5aa.up.railway.app

# Coach identity — used for single-coach dashboard (deprecated after COA-62 ships)
# Once auth is fully wired, coach_id comes from the JWT. Remove this var then.
COACH_ID=your-coach-uuid

# Organization ID (used for invite flows)
ORGANIZATION_ID=1

# ── OAuth providers ───────────────────────────────────────────────────────────
# Enable Google OAuth: Supabase dashboard → Auth → Providers → Google
#   Client ID + Secret from https://console.cloud.google.com/apis/credentials
#   Authorized redirect URI: https://your-project.supabase.co/auth/v1/callback
#
# Enable Apple OAuth: Supabase dashboard → Auth → Providers → Apple
#   Requires Apple Developer account, Service ID, and private key
#
# No env vars needed here — OAuth credentials live in the Supabase dashboard.

# ── Auth hook (REQUIRED — register after deploying COA-62) ───────────────────
# In Supabase dashboard → Authentication → Hooks → Custom Access Token:
#   Set hook function to: public.custom_access_token_hook
# This stamps coach_id + organization_id into every JWT, activating all RLS policies.
