# ── Coach.AI E2E Test Configuration ──────────────────────────────────────────
# Copy this file to .env and fill in the values before running.
# NEVER commit .env — it is in .gitignore.

# ── Railway URLs ──────────────────────────────────────────────────────────────
# The deployed Next.js frontend
FRONTEND_URL=https://your-frontend.up.railway.app

# The deployed FastAPI backend
BACKEND_URL=https://your-backend.up.railway.app

# ── Coach credentials ─────────────────────────────────────────────────────────
# The coach account you use to log in at /login
COACH_EMAIL=your-coach@example.com
COACH_PASSWORD=your-coach-password

# ── Test athlete ──────────────────────────────────────────────────────────────
# A real email address YOU control and can check during testing.
# Use a Gmail alias (yourname+athlete@gmail.com) so it's easy to filter.
TEST_ATHLETE_EMAIL=you+athlete@gmail.com

# Password the test will create for the new athlete account.
# Must be 8+ characters.
TEST_ATHLETE_PASSWORD=TestAthlete123!

# Full name used when sending the invite (can be anything)
TEST_ATHLETE_NAME=Test Athlete

# ── Supabase (for token extraction — avoids manual URL copy-paste) ───────────
# Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co

# The "anon public" key — used for password-based login in getCoachToken().
# This is the key that starts with "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..." and is safe to expose.
SUPABASE_ANON_KEY=your-anon-public-key

# The "service_role secret" key — used to query the DB directly (bypasses RLS).
# Keep this secret — never commit or share.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
